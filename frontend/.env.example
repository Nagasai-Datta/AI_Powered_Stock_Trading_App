# ─────────────────────────────────────────────────────────────
#  FRONTEND environment (the landing / login / signup site)
#  Copy to ".env" and fill in. On Vercel, set these in
#  Project Settings → Environment Variables.
#  NOTE: Create React App only reads REACT_APP_ variables, at
#  BUILD time — rebuild after changing them.
# ─────────────────────────────────────────────────────────────

# URL of your deployed BACKEND. Login and signup POST here.
# No trailing slash. Example: https://tradeit-backend.onrender.com
REACT_APP_BACKEND_URL=xxxxx

# URL of your DASHBOARD app — where users are sent after logging in.
# Example: https://tradeit-dashboard.vercel.app
REACT_APP_DASHBOARD_URL=xxxxx

PORT=xxxx
