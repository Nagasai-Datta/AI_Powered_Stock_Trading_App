# ─────────────────────────────────────────────────────────────
#  DASHBOARD environment (the trading terminal UI)
#  Copy to ".env" and fill in. On Vercel, set these in
#  Project Settings → Environment Variables.
#  NOTE: Create React App only reads variables that start with
#  REACT_APP_, and only at BUILD time — rebuild after changing.
# ─────────────────────────────────────────────────────────────

# URL of your deployed BACKEND (the Express server on Render).
# No trailing slash. Example: https://tradeit-backend.onrender.com
REACT_APP_BACKEND_URL=xxxxx

# URL of your LANDING page app — used to send the user back there
# after they sign out. Example: https://tradeit.vercel.app
REACT_APP_FRONTEND_URL=xxxxx
