# ─────────────────────────────────────────────────────────────
#  BACKEND environment (Express API + market engine)
#  Copy this file to ".env" and fill in the xxxxx values.
#  On Render, set these same keys in the service's Environment tab.
# ─────────────────────────────────────────────────────────────

# MongoDB connection string (MongoDB Atlas or self-hosted).
# Example: mongodb+srv://user:password@cluster.mongodb.net/tradeit
MONGO_URL=xxxxx

# OpenRouter API key — powers the AI chatbot (/chat).
# Get one at https://openrouter.ai/keys
API_KEY=xxxxx

# Any long random string. Signs BOTH the login session cookie and the
# Bearer auth token (the token is what keeps login working in Safari/Firefox).
# Example: a 32+ character random value.
SESSION_SECRET=xxxxx

# Optional: set this only if you want the token signed with a different
# secret than the session cookie. If unset, SESSION_SECRET is used.
# JWT_SECRET=xxxxx

# Port the server listens on. Render sets this automatically;
# 8080 is a fine default for local development.
PORT=8080


#uncomment when deploying in render
# NODE_ENV=production
